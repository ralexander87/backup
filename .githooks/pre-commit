#!/usr/bin/env bash

set -euo pipefail

if ! command -v shellcheck >/dev/null 2>&1; then
  echo "pre-commit: shellcheck not found, skipping shell lint"
  exit 0
fi

mapfile -t shell_files < <(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.sh$' || true)

if [[ ${#shell_files[@]} -eq 0 ]]; then
  exit 0
fi

echo "pre-commit: running shellcheck"
shellcheck "${shell_files[@]}"
