#!/usr/bin/env bash

set -euo pipefail

export PATH="/home/ralexander/.local/bin:$PATH"

if command -v shfmt >/dev/null 2>&1; then
  mapfile -t shell_files < <(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.sh$' || true)

  if [[ ${#shell_files[@]} -gt 0 ]]; then
    echo "pre-commit: checking shell formatting"
    shfmt -d -i 2 -ci "${shell_files[@]}"
  fi
fi

if ! command -v shellcheck >/dev/null 2>&1; then
  echo "pre-commit: shellcheck not found, skipping shell lint"
  exit 0
fi

mapfile -t shell_files < <(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.sh$' || true)

if [[ ${#shell_files[@]} -eq 0 ]]; then
  exit 0
fi

echo "pre-commit: running shellcheck"
shellcheck "${shell_files[@]}"
